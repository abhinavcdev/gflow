<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{.Title}}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/static/css/style.css">
</head>
<body>

  <!-- Nav -->
  <nav class="nav">
    <div class="container nav-inner">
      <a href="/" class="nav-logo"><span>g</span>flow</a>
      <ul class="nav-links">
        <li><a href="/#features">Features</a></li>
        <li><a href="/docs/getting-started">Docs</a></li>
        <li><a href="/docs/commands" class="active">Commands</a></li>
        <li><a href="https://github.com/abhinavcdev/gflow" target="_blank">GitHub</a></li>
        <li><a href="/docs/getting-started" class="btn-nav">Get Started &rarr;</a></li>
      </ul>
    </div>
  </nav>

  <div class="container">
    <div class="docs-layout">

      <!-- Sidebar -->
      <aside class="docs-sidebar">
        <nav class="docs-nav">
          <div class="docs-nav-label">Getting Started</div>
          <a href="/docs/getting-started">Installation</a>
          <a href="/docs/getting-started#token">GitHub Token</a>
          <a href="/docs/getting-started#init">Initialize</a>
          <a href="/docs/getting-started#first-workflow">First Workflow</a>
          <div class="docs-nav-label">Reference</div>
          <a href="/docs/commands" class="active">Commands</a>
          <a href="/docs/config">Configuration</a>
        </nav>
      </aside>

      <!-- Content -->
      <main class="docs-content">
        <h1>Commands</h1>
        <p>Complete reference for every gflow command. All commands read from <code>.gflow.yml</code> and respect your team's conventions.</p>

        <h2>Core Workflow</h2>

        {{range .Commands}}
        <div class="cmd-card">
          <div class="cmd-card-header">
            <span class="cmd-card-icon">{{.Icon}}</span>
            <span class="cmd-card-name">gflow {{.Name}}</span>
            {{if .Alias}}<span class="cmd-card-alias">alias: {{.Alias}}</span>{{end}}
          </div>
          <p>{{.Description}}</p>
          <span class="cmd-card-usage">{{.Usage}}</span>
        </div>
        {{end}}

        <div style="margin-top: var(--space-3xl); padding: var(--space-xl); background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg);">
          <h3 style="margin-top: 0;">Global Flags</h3>
          <p>These flags work with any command:</p>
          <ul>
            <li><code>--config &lt;path&gt;</code> &mdash; Path to config file (default: <code>.gflow.yml</code>)</li>
            <li><code>-v, --verbose</code> &mdash; Enable verbose output</li>
            <li><code>-h, --help</code> &mdash; Show help for any command</li>
          </ul>
          <p>Run <code>gflow [command] --help</code> for detailed flag info on any command.</p>
        </div>

      </main>
    </div>
  </div>

  <footer class="footer">
    <div class="container footer-inner">
      <span class="caption">Built with Go. Open source under MIT.</span>
      <ul class="footer-links">
        <li><a href="https://github.com/abhinavcdev/gflow" target="_blank">GitHub</a></li>
        <li><a href="/docs/getting-started">Docs</a></li>
        <li><a href="/docs/commands">Commands</a></li>
      </ul>
    </div>
  </footer>

  <script src="/static/js/main.js"></script>
</body>
</html>
