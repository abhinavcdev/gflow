<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{.Title}}</title>
  <meta name="description" content="{{.Description}}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/static/css/style.css">
</head>
<body>

  <!-- Nav -->
  <nav class="nav">
    <div class="container nav-inner">
      <a href="/" class="nav-logo"><span>g</span>flow</a>
      <ul class="nav-links">
        <li><a href="/#features">Features</a></li>
        <li><a href="/docs/getting-started">Docs</a></li>
        <li><a href="/docs/commands">Commands</a></li>
        <li><a href="https://github.com/abhinavcdev/gflow" target="_blank">GitHub</a></li>
        <li><a href="/docs/getting-started" class="btn-nav">Get Started &rarr;</a></li>
      </ul>
    </div>
  </nav>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-grid"></div>
    <div class="hero-badge">
      <span class="dot"></span>
      v0.1.0 &mdash; Now with real-time dashboard
    </div>

    <h1 class="display">
      Git workflows,<br>
      <span class="gradient-text">not git commands.</span>
    </h1>

    <p class="body-lg hero-sub">
      One CLI to branch, commit, PR, and merge. Encodes your team's conventions 
      into a single config file. Replaces git&#8209;flow, gh, and hub.
    </p>

    <div class="hero-actions">
      <a href="/docs/getting-started" class="btn-primary">Get Started &rarr;</a>
      <a href="https://github.com/abhinavcdev/gflow" class="btn-ghost" target="_blank">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
        Star on GitHub
      </a>
    </div>

    <div class="install-box">
      <span class="prompt">$</span>
      <span class="cmd">go install github.com/abhinavcdev/gflow@latest</span>
      <span class="copy-hint">click to copy</span>
    </div>
  </section>

  <!-- Terminal Demo -->
  <section class="terminal-section">
    <div class="container">
      <div class="terminal reveal">
        <div class="terminal-bar">
          <span class="terminal-dot red"></span>
          <span class="terminal-dot yellow"></span>
          <span class="terminal-dot green"></span>
          <span class="terminal-title">gflow &mdash; terminal</span>
        </div>
        <div class="terminal-body">
          <div class="line"><span class="prompt-char">$</span> <span class="cmd-text">gflow start feature user-auth</span></div>
          <div class="line"><span class="success">&nbsp;&nbsp;&#10003;</span> <span class="muted">Created feature/user-auth from main</span></div>
          <div class="line">&nbsp;</div>
          <div class="line"><span class="prompt-char">$</span> <span class="cmd-text">gflow pr "Add user authentication" --no-edit</span></div>
          <div class="line"><span class="success">&nbsp;&nbsp;&#10003;</span> <span class="muted">Committed changes</span></div>
          <div class="line"><span class="success">&nbsp;&nbsp;&#10003;</span> <span class="muted">Pushed feature/user-auth to origin</span></div>
          <div class="line"><span class="success">&nbsp;&nbsp;&#10003;</span> <span class="bold">Pull request created!</span></div>
          <div class="line">&nbsp;</div>
          <div class="line"><span class="success">&nbsp;&nbsp;&#10003;</span> <span class="violet">PR #42 created</span></div>
          <div class="line"><span class="muted">&nbsp;&nbsp;&nbsp;&nbsp;URL: https://github.com/you/repo/pull/42</span></div>
          <div class="line">&nbsp;</div>
          <div class="line"><span class="prompt-char">$</span> <span class="cmd-text">gflow finish</span></div>
          <div class="line"><span class="success">&nbsp;&nbsp;&#10003;</span> <span class="muted">9/9 checks passed</span></div>
          <div class="line"><span class="success">&nbsp;&nbsp;&#10003;</span> <span class="muted">Merged PR #42 via squash</span></div>
          <div class="line"><span class="success">&nbsp;&nbsp;&#10003;</span> <span class="bold">Finished feature/user-auth</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="features" id="features">
    <div class="container">
      <div class="section-head text-center reveal">
        <p class="section-label">Features</p>
        <h2 class="headline">Everything you need.<br><span class="gradient-text">Nothing you don't.</span></h2>
        <p class="body-lg mt-md" style="max-width: 500px; margin-left: auto; margin-right: auto;">
          Built in Go for speed. Designed for teams who ship fast.
        </p>
      </div>

      <div class="grid-3">
        {{range .Features}}
        <div class="feature-card reveal">
          <span class="feature-icon">{{.Icon}}</span>
          <h3>{{.Title}}</h3>
          <p>{{.Description}}</p>
          <span class="feature-tag">{{.Tag}}</span>
        </div>
        {{end}}
      </div>
    </div>
  </section>

  <!-- Workflow -->
  <section class="workflow">
    <div class="container">
      <div class="section-head text-center reveal">
        <p class="section-label">Workflow</p>
        <h2 class="headline">Three commands.<br><span class="gradient-text">Zero friction.</span></h2>
      </div>

      <div class="workflow-steps">
        <div class="workflow-step reveal">
          <div class="step-num">1</div>
          <div class="step-content">
            <h4>Start a branch</h4>
            <p>Creates a properly-prefixed branch from your base, synced with remote.</p>
            <span class="step-cmd">gflow start feature user-auth</span>
          </div>
        </div>
        <div class="workflow-step reveal">
          <div class="step-num">2</div>
          <div class="step-content">
            <h4>Open a PR</h4>
            <p>Stages changes, commits with conventions, pushes, and creates a PR with labels and reviewers.</p>
            <span class="step-cmd">gflow pr "Add user authentication"</span>
          </div>
        </div>
        <div class="workflow-step reveal">
          <div class="step-num">3</div>
          <div class="step-content">
            <h4>Finish &amp; clean up</h4>
            <p>Verifies CI checks, merges the PR, deletes the branch, switches back to main.</p>
            <span class="step-cmd">gflow finish</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Dashboard showcase -->
  <section class="terminal-section" style="border-top: 1px solid var(--border-subtle);">
    <div class="container">
      <div class="section-head text-center reveal">
        <p class="section-label">Dashboard</p>
        <h2 class="headline"><span class="gradient-text">gflow dash</span></h2>
        <p class="body-lg mt-md" style="max-width:500px; margin:0 auto;">
          Your entire project at a glance. 5 parallel goroutines. Sub-second fetch.
        </p>
      </div>

      <div class="terminal reveal" style="margin-top: var(--space-2xl);">
        <div class="terminal-bar">
          <span class="terminal-dot red"></span>
          <span class="terminal-dot yellow"></span>
          <span class="terminal-dot green"></span>
          <span class="terminal-title">gflow dash</span>
        </div>
        <div class="terminal-body" style="min-height: 380px;">
          <div class="line"><span class="violet bold">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;__ _</span></div>
          <div class="line"><span class="violet bold">&nbsp;&nbsp; __ _ / _| | _____      __</span></div>
          <div class="line"><span class="violet bold">&nbsp;&nbsp;/ _` | |_| |/ _ \ \ /\ / /</span></div>
          <div class="line"><span class="violet bold">&nbsp;| (_| |  _| | (_) \ V  V /</span></div>
          <div class="line"><span class="violet bold">&nbsp;&nbsp;\__, |_| |_|\___/ \_/\_/</span></div>
          <div class="line"><span class="violet bold">&nbsp;&nbsp;|___/</span></div>
          <div class="line"><span class="muted">&nbsp;&nbsp;fetched in 312ms using 5 parallel goroutines</span></div>
          <div class="line">&nbsp;</div>
          <div class="line"><span class="info">&nbsp;&nbsp;─── BRANCH ──────────────────────────────────</span></div>
          <div class="line"><span class="warn">&nbsp;&nbsp;&#10024;</span> <span class="bold">feature/user-auth</span> <span class="muted">(feature)</span></div>
          <div class="line"><span class="muted">&nbsp;&nbsp;&nbsp;&nbsp;base: main</span></div>
          <div class="line"><span class="success">&nbsp;&nbsp;&nbsp;&nbsp;sync: &#8593;3 ahead &nbsp;&#10003; in sync</span></div>
          <div class="line">&nbsp;</div>
          <div class="line"><span class="info">&nbsp;&nbsp;─── PULL REQUEST ────────────────────────────</span></div>
          <div class="line"><span class="success">&nbsp;&nbsp;●</span>  <span class="bold">#42 Add user authentication</span> <span class="muted">Open</span></div>
          <div class="line"><span class="muted">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;https://github.com/you/repo/pull/42</span></div>
          <div class="line">&nbsp;</div>
          <div class="line"><span class="info">&nbsp;&nbsp;─── RECENT COMMITS ──────────────────────────</span></div>
          <div class="line"><span class="warn">&nbsp;&nbsp;&#10024;</span> <span class="warn">a1b2c3d</span> feat: add auth middleware <span class="muted">2 min ago</span></div>
          <div class="line"><span class="warn">&nbsp;&nbsp;&#128027;</span> <span class="warn">d4e5f6g</span> fix: token validation <span class="muted">1 hour ago</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta">
    <div class="container">
      <div class="cta-box reveal">
        <p class="section-label">Get started</p>
        <h2 class="headline mt-sm">Ship faster with<br><span class="gradient-text">better workflows.</span></h2>
        <p class="body-lg mt-md mb-xl" style="max-width: 480px; margin-left: auto; margin-right: auto;">
          Install gflow, run init, and your team is on the same page. Forever.
        </p>
        <div class="install-box" style="animation: none; margin: 0 auto;">
          <span class="prompt">$</span>
          <span class="cmd">go install github.com/abhinavcdev/gflow@latest</span>
          <span class="copy-hint">click to copy</span>
        </div>
        <div style="margin-top: var(--space-xl); display: flex; justify-content: center; gap: var(--space-md);">
          <a href="/docs/getting-started" class="btn-primary">Read the Docs &rarr;</a>
          <a href="https://github.com/abhinavcdev/gflow" class="btn-ghost" target="_blank">View Source</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container footer-inner">
      <span class="caption">Built with Go. Open source under MIT.</span>
      <ul class="footer-links">
        <li><a href="https://github.com/abhinavcdev/gflow" target="_blank">GitHub</a></li>
        <li><a href="/docs/getting-started">Docs</a></li>
        <li><a href="/docs/commands">Commands</a></li>
        <li><a href="https://github.com/abhinavcdev/gflow/issues" target="_blank">Issues</a></li>
      </ul>
    </div>
  </footer>

  <script src="/static/js/main.js"></script>
</body>
</html>
